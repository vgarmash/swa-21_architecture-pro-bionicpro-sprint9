@startuml BionicPRO Enhanced Authentication Architecture
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

' ==== Метаданные и настройки ====
title Контейнерная диаграмма BionicPRO (Управление доступом)
'skinparam linetype ortho

' ==== Определение персон ====
Person(user, "Пользователь (Пациент)", "Покупатель и пользователь протеза. Авторизуется в системе через приложение.")

' ==== Определение программных систем ====
System_Boundary(bionicpro_boundary, "BionicPRO") {
    ' ----- Существующие контейнеры -----
    ' Container(alias, label, ?techn, ?descr, ?sprite, ?tags, ?link, ?baseShape)
    Container(frontend, "Мобильное приложение", "iOS / Android", "Фронтенд для донастройки протеза и просмотра отчетов.")
    Container(spa, "Веб-фронтенд", "React / TypeScript", "Интернет-магазин и портал для пользователей. (Битрикс24)")
    Container(crm, "CRM система", "Битрикс24", "Управление взаимоотношениями с клиентами, заказами.")
    ContainerDb(crm_db, "База данных CRM", "PostgreSQL", "Хранит операционные данные: заказы, профили клиентов, история обращений.")

    ' ----- НОВЫЕ контейнеры для аутентификации и управления доступом -----
    Container(auth_service, "Сервис аутентификации (BFF)", "Java / Spring Boot", "Backend-for-Frontend. Управляет сессиями, безопасно взаимодействует с Keycloak, возвращает HTTP-Only куки. Не передает токены фронтенду.")
    Container(keycloak, "Сервис идентификации (IdP/Broker)", "Keycloak", "Центральный Identity Provider и Identity Broker. Выпускает токены, управляет MFA, федерацией с LDAP и внешними IdP.")
    ContainerDb(ldap_eu, "LDAP-сервер (ЕС)", "OpenLDAP", "Хранит учетные записи и роли пользователей европейского представительства. Данные локализованы для GDPR.")
}

' ==== Внешние программные системы ====
System_Ext(yandex_id, "Яндекс ID", "Внешний Identity Provider для граждан РФ.", $type="OAuth 2.0 / OpenID Connect")
System_Ext(other_idp, "Другие IDP", "Внешние IdP для других стран (по мере выхода на рынок).", $type="OAuth 2.0 / OpenID Connect")

' ==== Критические связи и взаимодействия ====

' 1. Пользователь начинает аутентификацию через фронтенд
Rel(user, frontend, "Использует приложение для донастройки и отчетов", "HTTPS")
Rel(user, spa, "Пользуется интернет-магазином и порталом", "HTTPS")

' 2. Фронтенд делегирует аутентификацию BFF-сервису (больше не ходит в Keycloak напрямую)
Rel(frontend, auth_service, "Запрос на вход / проверка сессии", "HTTPS (REST/JSON)")
Rel(spa, auth_service, "Запрос на вход / проверка сессии", "HTTPS (REST/JSON)")

' 3. BFF-сервис реализует OAuth 2.0 PKCE flow с Keycloak
Rel(auth_service, keycloak, "PKCE Authorization Flow (code, code_verifier)", "HTTPS (OAuth 2.0)")

' 4. Keycloak синхронизирует пользователей с локальным LDAP региона
Rel(keycloak, ldap_eu, "Синхронизация учетных записей и ролей", "LDAPS")

' 5. Keycloak выступает брокером для внешних IdP
Rel_R(keycloak, yandex_id, "Identity Brokering. Запрашивает согласие (consent).", "OIDC")
Rel_R(keycloak, other_idp, "Identity Brokering", "OIDC")

' 6. BFF-сервис предоставляет доступ к основным сервисам (через сессию)
Rel(auth_service, crm, "Запрос данных пользователя (с внутренним токеном)", "HTTPS")
Rel(crm, crm_db, "Запрос и сохранение операционных данных", "JDBC")

' 7. Прямой доступ фронтенда к Keycloak для аутентификации УДАЛЕН (закомментированная строка)
' Rel(frontend, keycloak, "Устаревший небезопасный flow", "HTTPS")

@enduml