                                                                                                                             				<!-- ========= НОВЫЕ ЭЛЕМЕНТЫ ДЛЯ ЗАДАНИЯ 2: СЕРВИС ОТЧЁТОВ ========= -->
                                                                                                                             				<!-- Отчётный API -->
                                                                                                                             				<mxCell id="REPORT_API" value="&lt;font style=&quot;font-size: 16px&quot;&gt;&lt;b&gt;Отчётный API&lt;/b&gt;&lt;/font&gt;&lt;div&gt;[Container: Java/Spring Boot]&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;REST/gRPC-сервис для получения отчётов по user_id. Доступ через BFF. Авторизация через Keycloak.&lt;/font&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;labelBackgroundColor=none;fillColor=#FF9900;fontColor=#000000;align=center;arcSize=10;strokeColor=#CC6600;metaEdit=1;resizable=0;points=[[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0.25,0],[1,0.5,0],[1,0.75,0],[0.75,1,0],[0.5,1,0],[0.25,1,0],[0,0.75,0],[0,0.5,0],[0,0.25,0]];" vertex="1" parent="1">
                                                                                                                             					<mxGeometry height="120" width="260" x="810" y="580" as="geometry"/>
                                                                                                                             				</mxCell>
                                                                                                                             				<!-- OLAP-БД (ClickHouse) -->
                                                                                                                             				<mxCell id="OLAP_DB" value="&lt;font style=&quot;font-size: 16px&quot;&gt;&lt;b&gt;OLAP-БД&lt;/b&gt;&lt;/font&gt;&lt;div&gt;[Container: ClickHouse]&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;Витрина агрегированных отчётных данных: телеметрия + CRM. Поддержка быстрых аналитических запросов.&lt;/font&gt;&lt;/div&gt;" style="shape=cylinder3;size=15;whiteSpace=wrap;html=1;boundedLbl=1;rounded=0;labelBackgroundColor=none;fillColor=#FF9900;fontSize=12;fontColor=#000000;align=center;strokeColor=#CC6600;metaEdit=1;points=[[0.5,0,0],[1,0.25,0],[1,0.5,0],[1,0.75,0],[0.5,1,0],[0,0.75,0],[0,0.5,0],[0,0.25,0]];resizable=0;" vertex="1" parent="1">
                                                                                                                             					<mxGeometry height="120" width="240" x="1240" y="580" as="geometry"/>
                                                                                                                             				</mxCell>
                                                                                                                             				<!-- Apache Airflow (ETL) -->
                                                                                                                             				<mxCell id="AIRFLOW_ETL" value="&lt;font style=&quot;font-size: 16px&quot;&gt;&lt;b&gt;Apache Airflow (ETL)&lt;/b&gt;&lt;/font&gt;&lt;div&gt;[Container: Apache Airflow]&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;Планировщик и оркестратор ETL-пайплайнов: извлечение данных из PostgreSQL и CRM DB → трансформация → загрузка в OLAP-БД.&lt;/font&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;labelBackgroundColor=none;fillColor=#FF9900;fontColor=#000000;align=center;arcSize=10;strokeColor=#CC6600;metaEdit=1;resizable=0;points=[[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0.25,0],[1,0.5,0],[1,0.75,0],[0.75,1,0],[0.5,1,0],[0.25,1,0],[0,0.75,0],[0,0.5,0],[0,0.25,0]];" vertex="1" parent="1">
                                                                                                                             					<mxGeometry height="120" width="260" x="1030" y="380" as="geometry"/>
                                                                                                                             				</mxCell>
                                                                                                                             				<!-- ========= ЭЛЕМЕНТЫ ИЗ ИСХОДНОЙ ДИАГРАММЫ (для связей с BFF/Keycloak) ========= -->
                                                                                                                             				<!-- BFF -->
                                                                                                                             				<mxCell id="NEW_AUTH_SERVICE" value="&lt;font style=&quot;font-size: 16px&quot;&gt;&lt;b&gt;Сервис аутентификации (BFF)&lt;/b&gt;&lt;/font&gt;&lt;div&gt;[Container: Java / Spring Boot]&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;Backend-for-Frontend. Управляет сессии, безопасно взаимодействует с Keycloak, возвращает HTTP-Only куки. Не передает токены фронтенду.&lt;/font&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;labelBackgroundColor=none;fillColor=#FF9900;fontColor=#000000;align=center;arcSize=10;strokeColor=#CC6600;metaEdit=1;resizable=0;points=[[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0.25,0],[1,0.5,0],[1,0.75,0],[0.75,1,0],[0.5,1,0],[0.25,1,0],[0,0.75,0],[0,0.5,0],[0,0.25,0]];" vertex="1" parent="1">
                                                                                                                             					<mxGeometry height="120" width="280" x="780" y="380" as="geometry"/>
                                                                                                                             				</mxCell>
                                                                                                                             				<!-- Keycloak -->
                                                                                                                             				<mxCell id="NEW_KEYCLOAK" value="&lt;font style=&quot;font-size: 16px&quot;&gt;&lt;b&gt;Сервис идентификации (IdP/Broker)&lt;/b&gt;&lt;/font&gt;&lt;div&gt;[Container: Keycloak]&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;Центральный Identity Provider и Identity Broker. Выпускает токены, управляет MFA, федерацией с LDAP и внешними IdP.&lt;/font&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;labelBackgroundColor=none;fillColor=#FF9900;fontColor=#000000;align=center;arcSize=10;strokeColor=#CC6600;metaEdit=1;resizable=0;points=[[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0.25,0],[1,0.5,0],[1,0.75,0],[0.75,1,0],[0.5,1,0],[0.25,1,0],[0,0.75,0],[0,0.5,0],[0,0.25,0]];" vertex="1" parent="1">
                                                                                                                             					<mxGeometry height="120" width="280" x="1241" y="380" as="geometry"/>
                                                                                                                             				</mxCell>
                                                                                                                             				<!-- LDAP -->
                                                                                                                             				<mxCell id="NEW_LDAP_EU" value="&lt;font style=&quot;font-size: 16px&quot;&gt;&lt;b&gt;LDAP-сервер (ЕС)&lt;/b&gt;&lt;/font&gt;&lt;div&gt;[Container: OpenLDAP]&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;Хранит учетные записи и роли пользователей европейского представительства. Данные локализованы для GDPR.&lt;/font&gt;&lt;/div&gt;" style="shape=cylinder3;size=15;whiteSpace=wrap;html=1;boundedLbl=1;rounded=0;labelBackgroundColor=none;fillColor=#FF9900;fontSize=12;fontColor=#000000;align=center;strokeColor=#CC6600;metaEdit=1;points=[[0.5,0,0],[1,0.25,0],[1,0.5,0],[1,0.75,0],[0.5,1,0],[0,0.75,0],[0,0.5,0],[0,0.25,0]];resizable=0;" vertex="1" parent="1">
                                                                                                                                                                                                                                                                             					<mxGeometry height="120" width="240" x="1150" y="640" as="geometry"/>
                                                                                                                                                                                                                                                                             				</mxCell>
                                                                                                                                                                                                                                                                             				<!-- Яндекс ID -->
                                                                                                                                                                                                                                                                             				<mxCell id="NEW_YANDEX_ID" value="&lt;font style=&quot;font-size: 16px&quot;&gt;&lt;b&gt;Яндекс ID&lt;/b&gt;&lt;/font&gt;&lt;div&gt;[System: OAuth 2.0 / OpenID Connect]&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;Внешний Identity Provider для граждан РФ.&lt;/font&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;labelBackgroundColor=none;fillColor=#C4D8A2;fontColor=#333333;align=center;arcSize=10;strokeColor=#93B46B;metaEdit=1;resizable=0;points=[[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0.25,0],[1,0.5,0],[1,0.75,0],[0.75,1,0],[0.5,1,0],[0.25,1,0],[0,0.75,0],[0,0.5,0],[0,0.25,0]];" vertex="1" parent="1">
                                                                                                                                                                                                                                                                             					<mxGeometry height="120" width="240" x="1870" y="260" as="geometry"/>
                                                                                                                                                                                                                                                                             				</mxCell>
                                                                                                                                                                                                                                                                             				<!-- Другие IDP -->
                                                                                                                                                                                                                                                                             				<mxCell id="NEW_OTHER_IDP" value="&lt;font style=&quot;font-size: 16px&quot;&gt;&lt;b&gt;Другие IDP&lt;/b&gt;&lt;/font&gt;&lt;div&gt;[System: OAuth 2.0 / OpenID Connect]&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;Внешние IdP для других стран (по мере выхода на рынок).&lt;/font&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;labelBackgroundColor=none;fillColor=#C4D8A2;fontColor=#333333;align=center;arcSize=10;strokeColor=#93B46B;metaEdit=1;resizable=0;points=[[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0.25,0],[1,0.5,0],[1,0.75,0],[0.75,1,0],[0.5,1,0],[0.25,1,0],[0,0.75,0],[0,0.5,0],[0,0.25,0]];" vertex="1" parent="1">
                                                                                                                                                                                                                                                                             					<mxGeometry height="120" width="240" x="1870" y="420" as="geometry"/>
                                                                                                                                                                                                                                                                             				</mxCell>
