	"clients": [
		{
			"clientId": "reports-frontend",
			"name": "Reports Frontend",
			"description": "Reports Frontend Client",
			"protocol": "openid-connect",
			"publicClient": true,
			"redirectUris": [
				"http://localhost:3000/*"
			],
			"webOrigins": [
				"http://localhost:3000"
			],
			"standardFlowEnabled": true,
			"implicitFlowEnabled": false,
			"directAccessGrantsEnabled": false,
			"serviceAccountsEnabled": false,
			"attributes": {
				"pkce.code.challenge.method": "S256"
			},
			"protocolMappers": [
				{
					"name": "pkce code challenge method",
					"protocol": "openid-connect",
					"protocolMapper": "oidc-pkce-code-challenge-method-mapper",
					"config": {
						"pkce.code.challenge.method": "S256"
					}
				}
			]
		},
