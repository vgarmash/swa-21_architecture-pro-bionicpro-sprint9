# =============================================================================
# BionicPRO Environment Variables Configuration
# =============================================================================
#
# Этот файл содержит все переменные окружения, используемые в проекте BionicPRO.
# Сгруппированы по сервисам.
#
# ИНСТРУКЦИЯ ПО ИСПОЛЬЗОВАНИЮ:
# 1. Скопируйте этот файл как .env (если ещё не создан)
# 2. Заполните обязательные переменные (помечены "ЗАПОЛНИТЬ АКТУАЛЬНЫМИ ЗНАЧЕНИЯМИ")
# 3. При необходимости измените значения по умолчанию
#
# ПРИМЕЧАНИЕ:
# - Переменные БЕЗ значений по умолчанию требуют обязательного заполнения
# - Переменные СО значениями по умолчанию могут быть изменены при необходимости
#
# =============================================================================

# =============================================================================
# 1. KEYCLOAK (SSO Provider)
# =============================================================================
# Основные настройки Keycloak

KEYCLOAK_DB_USER=keycloak_user
KEYCLOAK_DB_PASSWORD=keycloak_password
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_BIONICPRO_AUTH_CLIENT_SECRET=mAu+Af98H0Bq5diUVwbU0ymE76Bqpx55

# =============================================================================
# 2. REDIS (Session Storage)
# =============================================================================
# Настройки Redis для хранения сессий

REDIS_PASSWORD=redis_password

# =============================================================================
# 3. POSTGRESQL (Source Databases)
# =============================================================================
# Настройки подключения к базам данных CRM и датчиков

# CRM Database
CRM_DB_USER=crm_user
CRM_DB_PASSWORD=crm_password

# Sensors Database
SENSORS_DB_USER=sensors_user
SENSORS_DB_PASSWORD=sensors_password

# =============================================================================
# 4. CLICKHOUSE (OLAP Database)
# =============================================================================
# Настройки ClickHouse для аналитики и отчётов

CLICKHOUSE_PASSWORD=clk_password

# =============================================================================
# 5. MINIO (Object Storage)
# =============================================================================
# Настройки MinIO для хранения файлов отчётов

MINIO_ROOT_USER=minio_user
MINIO_ROOT_PASSWORD=minio_password

# =============================================================================
# 6. LDAP (Authentication)
# =============================================================================
# Настройки LDAP сервера для аутентификации

LDAP_ADMIN_PASSWORD=admin

# =============================================================================
# 7. BIONICPRO-AUTH (Authentication Service)
# =============================================================================
# OAuth2 токены для шифрования (обязательные, без значений по умолчанию)

OAUTH2_AES_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
OAUTH2_SALT=42696f6e696350726f53656375726553616c7432303234

# Airflow Fernet Key (32 bytes, base64 encoded) - пример сгенерированного ключа
# AIRFLOW_FERNET_KEY ранее использовался, теперь настраивается в airflow/.env

# ----------------------------------------------------------------------
# Переменные со значениями по умолчанию (bionicpro-auth)
# ----------------------------------------------------------------------
# Эти переменные можно изменить при необходимости

# Redis - значения по умолчанию
# REDIS_HOST=redis                    # По умолчанию: redis (Docker network)
# REDIS_PORT=6379                    # По умолчанию: 6379
# REDIS_PASSWORD=                    # Требуется заполнить выше

# Keycloak - значения по умолчанию
# KEYCLOAK_SERVER_URL=http://keycloak:8080
# KEYCLOAK_PUBLIC_URL=http://localhost:8088
# KEYCLOAK_REALM=reports-realm
# KEYCLOAK_CLIENT_ID=bionicpro-auth
# KEYCLOAK_CLIENT_SECRET=changeme
# KEYCLOAK_REDIRECT_URI=http://localhost:8000/api/auth/callback

# OAuth2 - значения по умолчанию
# OAUTH2_AES_KEY=changeme            # Требуется заполнить выше
# OAUTH2_SALT=changeme               # Требуется заполнить выше

# Session - значения по умолчанию
# auth.session.timeout-minutes=30
# auth.session.cookie-name=BIONICPRO_SESSION
# auth.token.access-token-timeout-minutes=2
# auth.token.refresh-token-timeout-minutes=30

# Token encryption - значения по умолчанию
# auth.token.encryption.algorithm=AES
# auth.token.encryption.key-size=256
# auth.token.encryption.mode=CBC
# auth.token.encryption.padding=PKCS5Padding

# =============================================================================
# 8. BIONICPRO-REPORTS (Reports Service)
# =============================================================================
# Переменные со значениями по умолчанию (bionicpro-reports)

# ClickHouse - значения по умолчанию
# CLICKHOUSE_HOST=olap_db
# CLICKHOUSE_PORT=8123
# CLICKHOUSE_PORT=8123
# CLICKHOUSE_USER=default
# CLICKHOUSE_PASSWORD=                # Требуется заполнить выше

# Keycloak JWT - значения по умолчанию
# KEYCLOAK_ISSUER_URI=http://keycloak:8080/realms/reports-realm
# KEYCLOAK_JWK_SET_URI=http://keycloak:8080/realms/reports-realm/protocol/openid-connect/certs

# MinIO - значения по умолчанию
# MINIO_ENDPOINT=http://minio:9000
# MINIO_ROOT_USER=minioadmin
# MINIO_ROOT_PASSWORD=minioadmin
# MINIO_BUCKET_NAME=reports
# MINIO_PRESIGNED_EXPIRY=168         # 7 дней в часах
# CDN_BASE_URL=http://nginx-cdn:80
# minio.enabled=true

# =============================================================================
# 9. FRONTEND (React Application)
# =============================================================================
# Переменные Frontend

# REACT_APP_API_URL=http://localhost:8000

# =============================================================================
# 10. CDC (Change Data Capture)
# =============================================================================
# CDC переменные настраиваются в app/cdc/.env

# =============================================================================
# 11. AIRFLOW (ETL Processes)
# =============================================================================
# Airflow переменные настраиваются в airflow/.env

# =============================================================================
# 12. NGINX (Reverse Proxy / CDN)
# =============================================================================
# NGINX настраивается отдельно в app/nginx/nginx.conf
# CDN_BASE_URL=http://nginx-cdn:80
