# CDC Module Environment Variables

# Zookeeper
ZOOKEEPER_CLIENT_PORT=2181
ZOOKEEPER_TICK_TIME=2000

# Kafka
KAFKA_BROKER_ID=1
KAFKA_PORT=9092
KAFKA_INTERNAL_PORT=29092
KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR=1

# Kafka Connect
KAFKA_CONNECT_PORT=8083
KAFKA_CONNECT_GROUP_ID=cdc-connect-cluster
KAFKA_CONNECT_CONFIG_STORAGE_TOPIC=connect-configs
KAFKA_CONNECT_OFFSET_STORAGE_TOPIC=connect-offsets
KAFKA_CONNECT_STATUS_STORAGE_TOPIC=connect-status

# Debezium connectors configuration path
DEBEZIUM_CONFIG_PATH=/debezium-config

# PostgreSQL source databases (to be configured in connectors)
POSTGRES_CRM_HOST=crm-db
POSTGRES_CRM_PORT=5432
POSTGRES_CRM_DB=crm
POSTGRES_CRM_USER=postgres
POSTGRES_CRM_PASSWORD=postgres

POSTGRES_SENSORS_HOST=sensors-db
POSTGRES_SENSORS_PORT=5432
POSTGRES_SENSORS_DB=sensors
POSTGRES_SENSORS_USER=postgres
POSTGRES_SENSORS_PASSWORD=postgres
