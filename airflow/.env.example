# Airflow Core
AIRFLOW__CORE__FERNET_KEY=<generate-with: openssl rand -base64 32>
AIRFLOW__CORE__EXECUTOR=LocalExecutor

# Airflow Database
AIRFLOW_DB_HOST=postgres
AIRFLOW_DB_PORT=5432
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=<set-password>
AIRFLOW_DB_NAME=airflow

# Source Databases (connections to BionicPRO)
SENSORS_DB_HOST=sensors-db
SENSORS_DB_PORT=5432
SENSORS_DB_PASSWORD=<set-password>

CRM_DB_HOST=crm_db
CRM_DB_PORT=5432
CRM_DB_PASSWORD=<set-password>

OLAP_DB_HOST=olap_db
OLAP_DB_PORT=9000

# Airflow Admin
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=<set-password>
